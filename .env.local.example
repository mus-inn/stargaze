# Vercel API (for admin dashboard)
VERCEL_API_TOKEN=
VERCEL_ORG_ID=
VERCEL_EDGE_CONFIG_ID=

# Admin dashboard auth
ADMIN_USER=admin
ADMIN_PASS=change-me
ADMIN_SESSION_SECRET=generate-with-openssl-rand-hex-32

# Local dev only — Vercel auto-injects this in every deploy. The middleware
# derives the Edge Config key from it as `shadow-<slug>-canary`. Set it to
# your GitHub repo name (e.g. `my-app` for `owner/my-app`) so local dev
# reads/writes the same key as production. Without it, middleware passes
# through in dev with a one-time warn (so next dev stays usable), but prod
# throws.
VERCEL_GIT_REPO_SLUG=

# Optional: Slack notifications (used by GH Actions, not app)
# SLACK_WEBHOOK_URL=
