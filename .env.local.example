# Vercel API (for admin dashboard)
VERCEL_API_TOKEN=
VERCEL_ORG_ID=
VERCEL_EDGE_CONFIG_ID=

# Admin dashboard auth
ADMIN_USER=admin
ADMIN_PASS=change-me
ADMIN_SESSION_SECRET=generate-with-openssl-rand-hex-32

# Optional: shared-store mode — set when multiple shadow-canary projects share
# one Edge Config store (e.g. to sidestep Vercel Pro's 3-store limit). Use a
# unique value per project, like `shadow-configuration-<app>`. Leave unset to
# use the default key `shadow-configuration`.
# SHADOW_CANARY_KEY=shadow-configuration-myapp

# Optional: Slack notifications (used by GH Actions, not app)
# SLACK_WEBHOOK_URL=
